int main(int argc, char* argv[]) {
    QCoreApplication app(argc, argv);

    // 1. 创建构建器
    QMetaObjectBuilder builder;
    // builder.setClassName("MyDynamicClass");
    builder.setSuperClass(&QObject::staticMetaObject);

    // 2. 添加一个信号和一个槽
    auto signal = builder.addSignal("dynamicSignal(QString)");
    builder.addSlot("dynamicSlot(QString)");
    builder.addMethod("f(QString)");
    builder.addConstructor("d()");
    builder.removeMethod(builder.indexOfMethod("f(QString)"));

    builder.addProperty("name", "QString", signal.index());

    // 3. 设置静态 metacall 函数
    builder.setStaticMetacallFunction(qt_static_metacall);

    // 4. 构建元对象
    QMetaObject* dynamicMetaObject = builder.toMetaObject();
    QDynamicMetaObjectData* metaObject = new MyDynamicMetaObject(dynamicMetaObject);
    // for (int i = 0; i < dynamicMetaObject->methodCount(); ++i) {
    //     qDebug() << dynamicMetaObject->method(i).methodSignature();
    // }

    // 5. 创建实例并设置动态元对象
    QObject obj;
    QObjectPrivate::get(&obj)->metaObject = metaObject;
    // obj.setMetaObject(dynamicMetaObject);

    qDebug() << "???";

    // 6. 连接动态信号和动态槽
    int signalIdx = dynamicMetaObject->indexOfSignal("dynamicSignal(QString)");
    int slotIdx = dynamicMetaObject->indexOfSlot("dynamicSlot(QString)");
    QMetaObject::connect(&obj, signalIdx, &obj, slotIdx);

    // 7. 发射信号，预期会触发 myStaticMetacall 中的槽调用
    QMetaMethod signalMethod = dynamicMetaObject->method(signalIdx);
    signalMethod.invoke(&obj,
        Qt::DirectConnection,
        Q_ARG(QString, "Hello from metacall!"));

    obj.setProperty("name", "John");
    // obj.property("name");
    obj.setProperty("name2", "John2");

    dynamicMetaObject->newInstance();
    int id = dynamicMetaObject->indexOfMethod("f(QString)");

    auto method = dynamicMetaObject->method(dynamicMetaObject->indexOfMethod("f(QString)"));
    method.invoke(&obj,
        Qt::DirectConnection,
        Q_ARG(QString, "Hello from metacall!"));

    return 0;
}
